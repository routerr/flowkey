{
  "build": {
    "distDir": "frontend/dist",
    "devPath": "http://localhost:5173",
    "beforeDevCommand": "cd frontend && npm run dev",
    "beforeBuildCommand": ""
  },

  "package": {
    "productName": "flowkey",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": true
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.flowkey.app",
      "icon": [
        "icons/32x32.png",
        "icons/icon.ico"
      ],
      "windows": {
        "wix": {
          "fragmentPaths": [
            "./windows/fragments/firewall.wxs"
          ]
        }
      }
    },
    "security": {
      "csp": null
    },
    "systemTray": {
      "iconPath": "icons/icon.ico",
      "iconAsTemplate": true
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "flowkey Manager",
        "width": 800,
        "height": 600,
        "visible": false,
        "label": "main"
      }
    ]
  }
}
