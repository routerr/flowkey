{
  "build": {
    "distDir": "frontend/dist",
    "devPath": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },

  "package": {
    "productName": "flowkey",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": true
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.flowkey.app",
      "icon": [
        "icons/32x32.png"
      ]
    },
    "security": {
      "csp": null
    },
    "systemTray": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "flowkey Manager",
        "width": 800,
        "height": 600,
        "visible": false,
        "label": "main"
      }
    ]
  }
}
